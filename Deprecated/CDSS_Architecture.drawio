      <mxCell id="a-in-sq1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2E86C1;strokeWidth=2;" edge="1" source="input" target="sq1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="a-in-sq2" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2E86C1;strokeWidth=2;" edge="1" source="input" target="sq2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="a-in-sq3" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2E86C1;strokeWidth=2;" edge="1" source="input" target="sq3" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      <!-- ===== ROUTING ===== -->
      <!-- Layer 1: Regex -->
      <mxCell id="route1" value="Layer 1 — Deterministic (Regex)&#xa;―――――――――――――――――&#xa;FastAPI Regex scan detects&#xa;strict IDs or structured keywords&#xa;e.g. rs28897696, NM_007294.4&#xa;&#xa;⚡ Instant — no LLM invoked" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F39C12;strokeColor=#D68910;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" vertex="1" parent="1">
        <mxGeometry x="315" y="310" width="220" height="130" as="geometry"/>
      </mxCell>

      <!-- Layer 2: LLM Logical -->
      <mxCell id="route2" value="Layer 2 — Logical (Local LLM)&#xa;―――――――――――――――――&#xa;No strict ID found?&#xa;LLM performs semantic routing:&#xa;&#xa;→ Vector DB  (ACMG / NCCN rules)&#xa;→ ClinGen API (gene-specific&#xa;   expert panel adaptations)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E67E22;strokeColor=#A04000;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" vertex="1" parent="1">
        <mxGeometry x="315" y="475" width="220" height="155" as="geometry"/>
      </mxCell>

      <!-- ARROWS: SQ → Routing -->
      <mxCell id="a-sq1-r1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#F39C12;strokeWidth=2;" edge="1" source="sq1" target="route1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="a-sq2-r2" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#E67E22;strokeWidth=2;" edge="1" source="sq2" target="route2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="a-sq3-r2" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#E67E22;strokeWidth=2;" edge="1" source="sq3" target="route2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      <!-- ===== QUERY CONSTRUCTION ===== -->
      <!-- Text-to-SQL -->
      <mxCell id="sql" value="Text-to-SQL Constructor&#xa;―――――――――――――――――&#xa;LLM or Python script translates&#xa;English query → SQL command&#xa;&#xa;SELECT clinical_significance&#xa;FROM clinvar&#xa;WHERE rsid = 'rs28897696'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8E44AD;strokeColor=#6C3483;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=left;spacingLeft=10;" vertex="1" parent="1">
        <mxGeometry x="585" y="290" width="240" height="155" as="geometry"/>
      </mxCell>

      <!-- Self-Query Retriever -->
      <mxCell id="sqr" value="Self-Query Retriever&#xa;―――――――――――――――――&#xa;LLM generates simultaneously:&#xa;• Vector embedding for search&#xa;• Hard metadata filters:&#xa;&#xa;{&quot;gene&quot;: &quot;BRCA1&quot;,&#xa; &quot;source&quot;: &quot;ACMG_2015&quot;}&#xa;&#xa;→ Prevents hallucinations by&#xa;   restricting search space" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9B59B6;strokeColor=#6C3483;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=left;spacingLeft=10;" vertex="1" parent="1">
        <mxGeometry x="585" y="475" width="240" height="210" as="geometry"/>
      </mxCell>

      <!-- ClinGen BYPASS label -->
      <mxCell id="bypass-label" value="⚡ Direct API bypass&#xa;(No construction step needed)" style="text;html=1;strokeColor=#D35400;fillColor=#FDEBD0;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=9;fontColor=#A04000;dashed=1;" vertex="1" parent="1">
        <mxGeometry x="585" y="720" width="240" height="45" as="geometry"/>
      </mxCell>

      <!-- Local LLM note -->
      <mxCell id="local-llm" value="🔒 All construction runs LOCAL&#xa;Patient data never leaves&#xa;the secure environment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1C2833;strokeColor=#BDC3C7;strokeWidth=1;fontSize=9;fontColor=#BDC3C7;align=center;dashed=1;" vertex="1" parent="1">
        <mxGeometry x="585" y="790" width="240" height="55" as="geometry"/>
      </mxCell>

      <!-- ARROWS: Routing → Construction -->
      <mxCell id="a-r1-sql" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#8E44AD;strokeWidth=2;" edge="1" source="route1" target="sql" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="a-r2-sqr" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#9B59B6;strokeWidth=2;" edge="1" source="route2" target="sqr" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      <!-- ===== DATA SOURCES (Phase 4) ===== -->

      <!-- PostgreSQL -->
      <mxCell id="psql" value="🗄️ PostgreSQL&#xa;(ClinVar — Local)&#xa;―――――――――――&#xa;Stores variant IDs, rsIDs,&#xa;clinical significance records&#xa;&#xa;e.g. rs28897696 → Pathogenic&#xa;&#xa;✅ Air-gapped · Private · Fast" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#1F618D;strokeColor=#154360;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" vertex="1" parent="1">
        <mxGeometry x="875" y="270" width="250" height="160" as="geometry"/>
      </mxCell>

      <!-- Vector DB -->
      <mxCell id="vdb" value="🔮 Vector Database&#xa;(Medical Protocols — Local)&#xa;―――――――――――&#xa;ACMG classification rules&#xa;NCCN oncology guidelines&#xa;Embeddings: PubMedBERT&#xa;&#xa;✅ Air-gapped · Private · Fast" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#117A65;strokeColor=#0E6655;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" vertex="1" parent="1">
        <mxGeometry x="875" y="470" width="250" height="165" as="geometry"/>
      </mxCell>

      <!-- ClinGen API — NEW BLOCK -->
      <mxCell id="clingen" value="🌐 ClinGen REST API&#xa;(Expert Panels — External)&#xa;―――――――――――&#xa;Fetches real-time, gene-specific&#xa;ACMG rule adaptations from&#xa;ClinGen Expert Panels&#xa;&#xa;e.g. BRCA1 CDR variant rules&#xa;&#xa;⚠️ Live external call&#xa;   (No patient data sent)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#6C3483;strokeColor=#4A235A;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" vertex="1" parent="1">
        <mxGeometry x="875" y="680" width="250" height="185" as="geometry"/>
      </mxCell>

      <!-- Hybrid RAG callout -->
      <mxCell id="hybrid-label" value="🔀 Hybrid RAG&#xa;Local air-gapped DBs + Live external API" style="text;html=1;strokeColor=#6C3483;fillColor=#F4ECF7;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=9;fontColor=#6C3483;fontStyle=2;" vertex="1" parent="1">
