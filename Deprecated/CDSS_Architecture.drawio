        <mxGeometry x="55" y="330" width="210" height="90" as="geometry"/>
      </mxCell>
      <mxCell id="sq2" value="Sub-Query 2&#xa;―――――――――&#xa;Rule Retrieval&#xa;Fetch ACMG criteria for&#xa;pathogenic BRCA1 mutation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E86C1;strokeColor=#1A5276;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" vertex="1" parent="1">
        <mxGeometry x="55" y="460" width="210" height="90" as="geometry"/>
      </mxCell>
      <mxCell id="sq3" value="Sub-Query 3&#xa;―――――――――&#xa;Protocol Retrieval&#xa;Fetch NCCN oncology protocols&#xa;for breast cancer + BRCA1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E86C1;strokeColor=#1A5276;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" vertex="1" parent="1">
        <mxGeometry x="55" y="590" width="210" height="90" as="geometry"/>
      </mxCell>

