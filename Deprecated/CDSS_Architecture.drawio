      <mxCell id="a-sqr-vdb" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#117A65;strokeWidth=2;" edge="1" source="sqr" target="vdb" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      <!-- ClinGen bypass arrow: Route2 → ClinGen (skips Phase 3) -->
      <mxCell id="a-r2-clingen" value="Bypasses Phase 3" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6C3483;strokeWidth=2;dashed=1;fontStyle=2;fontSize=9;fontColor=#6C3483;exitX=1;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="route2" target="clingen" parent="1">
        <mxGeometry relative="1" as="geometry">
          <Array as="points">
            <mxPoint x="550" y="690"/>
            <mxPoint x="550" y="772"/>
            <mxPoint x="875" y="772"/>
          </Array>
        </mxGeometry>
      </mxCell>

      <!-- ===== VERIFICATION (Phase 5) ===== -->

      <!-- Cross-Encoder Re-Ranking -->
      <mxCell id="rerank" value="Cross-Encoder Re-Ranking&#xa;―――――――――――――――――&#xa;Analyzes query ↔ chunk&#xa;semantic relationship&#xa;&#xa;Model: ms-marco-MiniLM-L-6-v2&#xa;&#xa;→ Forces most clinically accurate&#xa;   chunk to position [0]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E74C3C;strokeColor=#A93226;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" vertex="1" parent="1">
        <mxGeometry x="1175" y="270" width="240" height="165" as="geometry"/>
      </mxCell>

      <!-- CRAG Evaluator -->
      <mxCell id="crag" value="CRAG Evaluator Agent&#xa;―――――――――――――――――&#xa;Grades every retrieved chunk:&#xa;&#xa;✅ Correct   → Pass downstream&#xa;⚠️ Ambiguous → Trigger fallback&#xa;❌ Incorrect  → Reject + retry&#xa;&#xa;Applies to ALL sources:&#xa;PostgreSQL · VectorDB · ClinGen" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C0392B;strokeColor=#922B21;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" vertex="1" parent="1">
        <mxGeometry x="1175" y="470" width="240" height="195" as="geometry"/>
      </mxCell>

      <!-- ARROWS: Data Sources → Verification -->
      <mxCell id="a-psql-rr" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#E74C3C;strokeWidth=2;" edge="1" source="psql" target="rerank" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="a-vdb-crag" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#C0392B;strokeWidth=2;" edge="1" source="vdb" target="crag" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      <!-- ClinGen → CRAG arrow -->
      <mxCell id="a-clingen-crag" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6C3483;strokeWidth=2;" edge="1" source="clingen" target="crag" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      <!-- CRAG Fallback loop -->
      <mxCell id="a-crag-fallback" value="Fallback: Re-query" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#E74C3C;strokeWidth=1;dashed=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;endArrow=block;fontSize=9;fontStyle=2;fontColor=#E74C3C;" edge="1" source="crag" target="sqr" parent="1">
        <mxGeometry relative="1" as="geometry">
          <Array as="points">
            <mxPoint x="1160" y="567"/>
            <mxPoint x="560" y="567"/>
          </Array>
        </mxGeometry>
      </mxCell>

      <!-- ===== GENERATION (Phase 6) ===== -->

      <!-- Strict Prompting -->
      <mxCell id="prompt" value="Strict System Prompting&#xa;―――――――――――――――――&#xa;LLM restricted ONLY to verified&#xa;context. No external knowledge.&#xa;&#xa;Insufficient data triggers:&#xa;&quot;Insufficient clinical data to&#xa;safely provide an assessment.&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#922B21;strokeColor=#641E16;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" vertex="1" parent="1">
        <mxGeometry x="1465" y="270" width="240" height="160" as="geometry"/>
      </mxCell>

      <!-- Self-RAG -->
      <mxCell id="selfrag" value="Self-RAG Internal Critic&#xa;―――――――――――――――――&#xa;① Generate hidden draft&#xa;② Verify every claim against&#xa;   retrieved &amp; verified chunks&#xa;③ Unverified drafts → Reject&#xa;④ Auto-rewrite until verified" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7B241C;strokeColor=#4A235A;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" vertex="1" parent="1">
        <mxGeometry x="1465" y="460" width="240" height="155" as="geometry"/>
      </mxCell>

      <!-- Forced Citations -->
      <mxCell id="cite" value="Forced Citations (Audit Trail)&#xa;―――――――――――――――――&#xa;Every claim appends exact source:&#xa;&#xa;[Source: ClinVar, rs28897696]&#xa;[Source: ACMG_2015, PVS1]&#xa;[Source: ClinGen, BRCA1-EP]&#xa;[Source: NCCN, Breast-v3.2024]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#641E16;strokeColor=#4A235A;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" vertex="1" parent="1">
        <mxGeometry x="1465" y="645" width="240" height="160" as="geometry"/>
      </mxCell>

      <!-- ARROWS: Verification → Generation -->
      <mxCell id="a-rr-prompt" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#922B21;strokeWidth=2;" edge="1" source="rerank" target="prompt" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="a-crag-selfrag" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#7B241C;strokeWidth=2;" edge="1" source="crag" target="selfrag" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      <mxCell id="a-selfrag-cite" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#641E16;strokeWidth=2;" edge="1" source="selfrag" target="cite" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      <!-- ===== FINAL OUTPUT ===== -->
      <mxCell id="output" value="✅ Verified Clinical Response&#xa;―――――――――――――――&#xa;rs28897696 is Pathogenic.&#xa;ACMG: PVS1 (very strong)&#xa;            PS1 (strong)&#xa;NCCN: Annual MRI + mammogram&#xa;ClinGen: BRCA1 EP adaptation&#xa;&#xa;[Source: ClinVar, rs28897696]&#xa;[Source: ACMG_2015, PVS1]&#xa;[Source: ClinGen, BRCA1-EP]&#xa;[Source: NCCN, Breast-v3.2024]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E8449;strokeColor=#145A32;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;fontStyle=1;" vertex="1" parent="1">
        <mxGeometry x="1755" y="400" width="170" height="300" as="geometry"/>
      </mxCell>
      <mxCell id="a-cite-out" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#27AE60;strokeWidth=3;" edge="1" source="cite" target="output" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>

      <!-- ===== LEGEND ===== -->
      <!-- Legend background container -->
      <mxCell id="legend-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8F9FA;strokeColor=#CCCCCC;strokeWidth=1;" vertex="1" parent="1">
        <mxGeometry x="40" y="1170" width="1900" height="90" as="geometry"/>
      </mxCell>

      <!-- Legend title -->
      <mxCell id="legend-title" value="LEGEND" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
        <mxGeometry x="55" y="1175" width="80" height="20" as="geometry"/>
      </mxCell>

      <!-- ROW 1 — solid color items, each 185px wide, 10px gap, starting x=55 -->
      <!-- Item 1: Query Decomposition — x=55 -->
      <mxCell id="l1" value="Query Decomposition" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E86C1;strokeColor=#1A5276;fontSize=9;fontColor=#FFFFFF;align=center;" vertex="1" parent="1">
        <mxGeometry x="145" y="1180" width="185" height="28" as="geometry"/>
