# ── PostgreSQL (ClinVar local database) ──────────────────────────
POSTGRES_USER=cdss_user
POSTGRES_PASSWORD=cdss_password
POSTGRES_DB=cdss_db
POSTGRES_PORT=5432
POSTGRES_URL=postgresql://cdss_user:cdss_password@localhost:5432/cdss_db

# ── pgAdmin (web UI to manage the database) ───────────────────────
PGADMIN_DEFAULT_EMAIL=admin@cdss.com
PGADMIN_DEFAULT_PASSWORD=admin123

# ── Local LLM via Ollama ──────────────────────────────────────────
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=gemma4:26b

# ── Embedding Models ──────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# ── ClinGen API (no login needed, public endpoint) ───────────────
CLINGEN_API_URL=https://search.clinicalgenome.org/kb

HF_HUB_DISABLE_SYMLINKS_WARNING=1
HF_HUB_DISABLE_SYMLINKS=1

DOCLING_NUM_THREADS=6
OMP_NUM_THREADS=6
TOKENIZERS_PARALLELISM=false
DOCLING_VERBOSE=1