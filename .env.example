# ── PostgreSQL (ClinVar local database) ──────────────────────────
POSTGRES_URL=postgresql://cdss-user:cdss_password@localhost:5432/cdss_db
POSTGRES_USER=cdss-user
POSTGRES_PASSWORD=cdss_password
POSTGRES_DB=cdss_db
POSTGRES_PORT=5432

# ── Local LLM via Ollama ──────────────────────────────────────────
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=ministral-3:14b

# ── Embedding Models ──────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# ── ClinGen API (no login needed, public endpoint) ───────────────
CLINGEN_API_URL=https://search.clinicalgenome.org/kb

# ── Privacy: gnomAD external lookup ──────────────────────────────
# Set to false to disable external gnomAD API calls (air-gapped mode)
ENABLE_GNOMAD_LOOKUP=true
