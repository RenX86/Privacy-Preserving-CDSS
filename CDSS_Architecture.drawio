                <mxCell id="input" value="👨‍⚕️ Clinician Query&#xa;&#xa;&quot;What is the clinical significance&#xa;of rs28897696 and what are the&#xa;ACMG criteria and NCCN protocols&#xa;for pathogenic BRCA1 mutations?&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#4A90D9;strokeWidth=2;fontSize=11;fontColor=#FFFFFF;align=center;fontStyle=1;" parent="1" vertex="1">
