                <mxCell id="route1" value="Layer 1 — Deterministic (Regex)&#xa;―――――――――――――――――&#xa;FastAPI Regex scan detects strict&#xa;IDs or structured keywords&#xa;(e.g. rs28897696)&#xa;&#xa;⚡ Instant routing to PostgreSQL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F39C12;strokeColor=#D68910;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" parent="1" vertex="1">
                    <mxGeometry x="315" y="320" width="220" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="route2" value="Layer 2 — Logical (LLM Router)&#xa;―――――――――――――――――&#xa;If no strict ID found, Local LLM&#xa;performs intelligent routing:&#xa;&#xa;→ Vector DB  (ACMG/NCCN rules)&#xa;→ ClinGen API (gene-specific)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E67E22;strokeColor=#A04000;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" parent="1" vertex="1">
                    <mxGeometry x="315" y="480" width="220" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="a-sq1-r1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#F39C12;strokeWidth=2;dashed=0;" parent="1" source="sq1" target="route1" edge="1">
