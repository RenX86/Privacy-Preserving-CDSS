                <mxCell id="psql" value="🗄️ PostgreSQL&#xa;(ClinVar Structured Data)&#xa;―――――――――――&#xa;Stores variant IDs, rsIDs,&#xa;clinical significance records&#xa;e.g. rs28897696 → Pathogenic" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#1F618D;strokeColor=#154360;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" parent="1" vertex="1">
                    <mxGeometry x="875" y="280" width="230" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="vdb" value="🔮 Vector Database&#xa;(Medical Protocols)&#xa;―――――――――――&#xa;ACMG classification rules&#xa;NCCN oncology guidelines&#xa;ClinicalBERT embeddings" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#117A65;strokeColor=#0E6655;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" parent="1" vertex="1">
