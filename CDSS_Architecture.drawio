                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="rerank" value="Cross-Encoder Re-Ranking&#xa;―――――――――――――――――&#xa;Deeply analyzes query ↔ chunk&#xa;semantic relationship&#xa;&#xa;Model: ms-marco-MiniLM-L-6-v2&#xa;&#xa;→ Forces most clinically accurate&#xa;   rule to top position" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1ABC9C;strokeColor=#148F77;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" parent="1" vertex="1">
                    <mxGeometry x="1155" y="280" width="240" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="crag" value="CRAG Evaluator Agent&#xa;―――――――――――――――――&#xa;Grades each retrieved chunk:&#xa;&#xa;✅ Correct → Pass to generation&#xa;⚠️ Ambiguous → Trigger fallback&#xa;❌ Incorrect → Reject + retry&#xa;&#xa;Ensures only verified context&#xa;reaches the LLM generator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16A085;strokeColor=#0E6655;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" parent="1" vertex="1">
                    <mxGeometry x="1155" y="460" width="240" height="180" as="geometry"/>
