                <mxCell id="selfrag" value="Self-RAG Internal Critic&#xa;―――――――――――――――――&#xa;1. Generate hidden draft&#xa;2. Verify every claim against&#xa;   retrieved chunks&#xa;3. Unverified drafts → Reject&#xa;4. Auto-rewrite until verified" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C0392B;strokeColor=#922B21;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" parent="1" vertex="1">
                    <mxGeometry x="1430" y="380" width="185" height="150" as="geometry"/>
