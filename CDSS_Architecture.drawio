                </mxCell>
                <mxCell id="a-sq3-r2" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#E67E22;strokeWidth=2;" parent="1" source="sq3" target="route2" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="sql" value="Text-to-SQL Constructor&#xa;―――――――――――――――――&#xa;LLM or Python script translates&#xa;English query → SQL command&#xa;&#xa;SELECT clinical_significance&#xa;FROM clinvar&#xa;WHERE rsid = &#39;rs28897696&#39;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8E44AD;strokeColor=#6C3483;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=left;spacingLeft=10;" parent="1" vertex="1">
                    <mxGeometry x="585" y="300" width="240" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="sqr" value="Self-Query Retriever&#xa;―――――――――――――――――&#xa;LLM generates:&#xa;• Vector embedding for semantic search&#xa;• Hard metadata filters extracted:&#xa;&#xa;{&quot;gene&quot;: &quot;BRCA1&quot;,&#xa; &quot;source&quot;: &quot;ACMG_2015&quot;}&#xa;&#xa;→ Prevents hallucinations by&#xa;   restricting search space" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#9B59B6;strokeColor=#6C3483;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=left;spacingLeft=10;" parent="1" vertex="1">
