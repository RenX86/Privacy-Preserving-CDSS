                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="prompt" value="Strict System Prompting&#xa;―――――――――――――――――&#xa;LLM restricted ONLY to provided&#xa;verified context. No external&#xa;knowledge allowed.&#xa;&#xa;Insufficient data →&#xa;&quot;Insufficient clinical data to&#xa;safely provide an assessment.&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E74C3C;strokeColor=#A93226;strokeWidth=2;fontSize=10;fontColor=#FFFFFF;align=center;" parent="1" vertex="1">
                    <mxGeometry x="1430" y="190" width="185" height="160" as="geometry"/>
